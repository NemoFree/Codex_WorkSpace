{
  "info": {
    "name": "Internal KB AI Gateway MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "MVP API collection for internal knowledge base and AI gateway services."
  },
  "variable": [
    { "key": "gateway_base", "value": "http://localhost:8080" },
    { "key": "identity_base", "value": "http://localhost:8081" },
    { "key": "knowledge_base", "value": "http://localhost:8082" },
    { "key": "ai_base", "value": "http://localhost:8083" },
    { "key": "ops_base", "value": "http://localhost:8084" },
    { "key": "tenant_id", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "user_id", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "role", "value": "admin" },
    { "key": "session_id", "value": "" },
    { "key": "document_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway health",
          "request": { "method": "GET", "url": "{{gateway_base}}/healthz" }
        },
        {
          "name": "Knowledge health",
          "request": { "method": "GET", "url": "{{knowledge_base}}/healthz" }
        },
        {
          "name": "AI health",
          "request": { "method": "GET", "url": "{{ai_base}}/healthz" }
        }
      ]
    },
    {
      "name": "Identity",
      "item": [
        {
          "name": "Get me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "url": "{{identity_base}}/v1/me"
          }
        }
      ]
    },
    {
      "name": "Knowledge",
      "item": [
        {
          "name": "Create document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Ô±ą¤ĘÖ˛á\",\n  \"source_type\": \"upload\",\n  \"storage_uri\": \"s3://kb/manual.pdf\"\n}"
            },
            "url": "{{knowledge_base}}/v1/documents"
          }
        },
        {
          "name": "List documents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "url": "{{knowledge_base}}/v1/documents"
          }
        },
        {
          "name": "RAG search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Ô±ą¤ÇëĽŮÁ÷łĚ\",\n  \"top_k\": 5\n}"
            },
            "url": "{{knowledge_base}}/v1/rag/search"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Create session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"HR ÖúĘÖ»á»°\"\n}"
            },
            "url": "{{ai_base}}/v1/chat/sessions"
          }
        },
        {
          "name": "Send message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Çë×Ü˝áÔ±ą¤ÇëĽŮąćÔň\",\n  \"model\": \"gpt-4o-mini\"\n}"
            },
            "url": "{{ai_base}}/v1/chat/sessions/{{session_id}}/messages"
          }
        },
        {
          "name": "List messages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "url": "{{ai_base}}/v1/chat/sessions/{{session_id}}/messages"
          }
        }
      ]
    },
    {
      "name": "Ops",
      "item": [
        {
          "name": "Audit logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "url": "{{ops_base}}/v1/admin/audit/logs"
          }
        },
        {
          "name": "Get quotas",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-Role", "value": "{{role}}" }
            ],
            "url": "{{ops_base}}/v1/admin/quotas/{{tenant_id}}"
          }
        }
      ]
    }
  ]
}
